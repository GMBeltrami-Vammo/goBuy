# ── NextAuth (Auth.js) ──────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials from Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URI must include: {SITE_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Required in production (Vercel will set this automatically via VERCEL_URL,
# but you can override it explicitly if needed):
# AUTH_URL=https://your-gobuy.vercel.app

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project "Vammo Automations" — get from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://jfdqlnpidynxwqqiblcd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_gWWjGuyL11zqZPGgOT-KYw_UcfW0gFf

# Service role key — server only, NEVER commit a real value.
SUPABASE_SECRET_KEY=

# JWT Secret — used to mint Supabase-compatible tokens so RLS (auth.email())
# works with NextAuth sessions. Get from Supabase Dashboard → Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=

# ── Charges demo (heads-only approve/deny) ──────────────────────────────────
# Comma-separated @vammo.com emails allowed to see the FULL app. Everyone else
# who heads a cost center sees only the /cobrancas approval demo.
FULL_APP_ADMINS=gabriel.beltrami@vammo.com

# Shared secret for the inbound charges API (POST /api/charges).
# The external sender passes it as: Authorization: Bearer <this value>.
# Generate: openssl rand -base64 32
CHARGES_INBOUND_SECRET=

# Sent to the Google Apps Script webhook when a head approves a charge, so the
# script writes TRUE back to the source row. Must match the script's secret.
HEAD_APPROVAL_KEY=
# Optional override for the Apps Script /exec URL (defaults to the current one in code).
HEAD_APPROVAL_WEBHOOK_URL=
# Optional override for the CONFIDENTIAL "RH" charges write-back (separate Apps
# Script). Defaults to the current RH /exec URL in code. Same secret as above.
HEAD_APPROVAL_WEBHOOK_URL_RH=

# ── Slack notifications ─────────────────────────────────────────────────────
# Bot token (xoxb-…) for the goBuy Slack app. Scopes needed: chat:write,
# im:write, and users:read.email (to resolve heads by email + authorize the
# clicker on approve/deny). Reinstall the app after adding a scope.
SLACK_BOT_TOKEN=
# Signing secret — verifies interaction payloads (HMAC) on /api/slack/interact.
SLACK_SIGNING_SECRET=

# ── Cron (quiet-hours Slack drain) ──────────────────────────────────────────
# Protects GET /api/cron/slack-drain. Vercel Cron sends it as
# `Authorization: Bearer <CRON_SECRET>`. Generate: openssl rand -base64 32.
# The schedule (12:00 UTC = 09:00 BRT) lives in vercel.json.
CRON_SECRET=
